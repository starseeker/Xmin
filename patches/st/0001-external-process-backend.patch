@@ -945,6 +950,96 @@ ttyhangup(void)
 	kill(pid, SIGHUP);
 }
 
+#else
+
+int
+ttynew(const char *line, char *cmd, const char *out, char **args)
+{
+	struct xmin_pty_options options = {
+		.line = line,
+		.command = cmd,
+		.output = out,
+		.arguments = args,
+		.shell = cmd,
+		.scroll = scroll,
+		.utmp = utmp,
+		.stty_args = stty_args,
+		.termname = termname,
+	};
+	if (out)
+		term.mode |= MODE_PRINT;
+	return xmin_pty_open(&options);
+}
+
+size_t
+ttyread(void)
+{
+	static char buf[BUFSIZ];
+	static int buflen;
+	ssize_t received;
+	int written;
+
+	received = xmin_pty_read(buf + buflen, LEN(buf) - buflen);
+	if (received == 0)
+		exit(0);
+	if (received < 0) {
+		if (errno == EINTR)
+			return 0;
+		die("couldn't read from terminal backend: %s\n", strerror(errno));
+	}
+	buflen += received;
+	written = twrite(buf, buflen, 0);
+	buflen -= written;
+	if (buflen > 0)
+		memmove(buf, buf + written, buflen);
+	return received;
+}
+
+static void
+ttywriteraw(const char *data, size_t length)
+{
+	if (xmin_pty_write(data, length) < 0)
+		die("write error on terminal backend: %s\n", strerror(errno));
+}
+
+void
+ttywrite(const char *data, size_t length, int may_echo)
+{
+	const char *next;
+	if (may_echo && IS_SET(MODE_ECHO))
+		twrite(data, length, 1);
+	if (!IS_SET(MODE_CRLF)) {
+		ttywriteraw(data, length);
+		return;
+	}
+	while (length > 0) {
+		if (*data == '\r') {
+			next = data + 1;
+			ttywriteraw("\r\n", 2);
+		} else {
+			next = memchr(data, '\r', length);
+			DEFAULT(next, data + length);
+			ttywriteraw(data, next - data);
+		}
+		length -= next - data;
+		data = next;
+	}
+}
+
+void
+ttyresize(int width, int height)
+{
+	xmin_pty_resize(term.row, term.col, width, height);
+}
+
+void
+ttyhangup(void)
+{
+	xmin_pty_hangup();
+}
