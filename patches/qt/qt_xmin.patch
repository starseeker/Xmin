new file mode 100644
--- /dev/null
+++ b/src/plugins/platforms/xcb/gl_integrations/xcb_xmin/qxcbxmincontext.cpp
@@ -0,0 +1,109 @@
+// Copyright (C) 2026 Xmin Project
+// SPDX-License-Identifier: LicenseRef-Qt-Commercial OR LGPL-3.0-only OR GPL-2.0-only OR GPL-3.0-only
+
+#include "qxcbxmincontext.h"
+
+#include "qxcbconnection.h"
+#include "qxcbscreen.h"
+#include "qxcbwindow.h"
+
+#include <QtGui/QOpenGLContext>
+#include <Xmin/GLXxcb.h>
+
+#include <cstdlib>
+
+QT_BEGIN_NAMESPACE
+
+QXcbXminContext::QXcbXminContext(QXcbConnection *connection,
+                                 QOpenGLContext *context)
+{
+    auto *screen = static_cast<QXcbScreen *>(context->screen()->handle());
+    m_format = screen->surfaceFormatFor(context->format());
+    m_format.setRenderableType(QSurfaceFormat::OpenGL);
+    m_format.setVersion(2, 0);
+    m_format.setProfile(QSurfaceFormat::NoProfile);
+
+    m_display = xminGlxCreateXcbDisplay(connection->xcb_connection());
+    if (!m_display)
+        return;
+
+    if (context->shareHandle()) {
+        const auto *share =
+            static_cast<const QXcbXminContext *>(context->shareHandle());
+        m_shareContext = share->m_context;
+    }
+
+    const int attributes[] = {
+        GLX_DRAWABLE_TYPE, GLX_WINDOW_BIT,
+        GLX_RENDER_TYPE, GLX_RGBA_BIT,
+        GLX_DOUBLEBUFFER,
+            m_format.swapBehavior() == QSurfaceFormat::SingleBuffer
+                ? False : True,
+        GLX_RED_SIZE, qMax(1, m_format.redBufferSize()),
+        GLX_GREEN_SIZE, qMax(1, m_format.greenBufferSize()),
+        GLX_BLUE_SIZE, qMax(1, m_format.blueBufferSize()),
+        GLX_ALPHA_SIZE, qMax(0, m_format.alphaBufferSize()),
+        GLX_DEPTH_SIZE, qMax(0, m_format.depthBufferSize()),
+        GLX_STENCIL_SIZE, qMax(0, m_format.stencilBufferSize()),
+        0
+    };
+    int count = 0;
+    GLXFBConfig *configs = glXChooseFBConfig(
+        m_display, screen->screenNumber(), attributes, &count);
+    if (configs && count > 0) {
+        const int contextAttributes[] = {
+            GLX_CONTEXT_MAJOR_VERSION_ARB, 2,
+            GLX_CONTEXT_MINOR_VERSION_ARB, 0,
+            0
+        };
+        m_context = glXCreateContextAttribsARB(
+            m_display, configs[0], m_shareContext, True, contextAttributes);
+        if (!m_context && m_shareContext) {
+            m_shareContext = nullptr;
+            m_context = glXCreateContextAttribsARB(
+                m_display, configs[0], nullptr, True, contextAttributes);
+        }
+    }
+    std::free(configs);
+}
+
+QXcbXminContext::~QXcbXminContext()
+{
+    if (m_context)
+        glXDestroyContext(m_display, m_context);
+    xminGlxDestroyXcbDisplay(m_display);
+}
+
+bool QXcbXminContext::makeCurrent(QPlatformSurface *surface)
+{
+    if (!m_context || !surface ||
+        surface->surface()->surfaceClass() != QSurface::Window) {
+        return false;
+    }
+    auto *window = static_cast<QXcbWindow *>(surface);
+    return glXMakeCurrent(m_display, window->xcb_window(), m_context);
+}
+
+void QXcbXminContext::doneCurrent()
+{
+    if (m_display)
+        glXMakeCurrent(m_display, 0, nullptr);
+}
+
+void QXcbXminContext::swapBuffers(QPlatformSurface *surface)
+{
+    if (!surface || surface->surface()->surfaceClass() != QSurface::Window)
+        return;
+    auto *window = static_cast<QXcbWindow *>(surface);
+    glXSwapBuffers(m_display, window->xcb_window());
+    if (window->needsSync())
+        window->postSyncWindowRequest();
+}
+
+QFunctionPointer QXcbXminContext::getProcAddress(const char *procName)
+{
+    return reinterpret_cast<QFunctionPointer>(
+        glXGetProcAddress(reinterpret_cast<const GLubyte *>(procName)));
+}
+
+QT_END_NAMESPACE
