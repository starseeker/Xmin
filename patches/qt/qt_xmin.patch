+bool QXcbXminIntegration::initialize(QXcbConnection *connection)
+{
+    m_connection = connection;
+    qCDebug(lcQpaGl) << "Xmin software-direct xcb GL integration initialized";
+    return connection && connection->xcb_connection();
+}
+
+QXcbWindow *QXcbXminIntegration::createWindow(QWindow *window) const
+{
+    return new QXcbWindow(window);
+}
+
+#ifndef QT_NO_OPENGL
+QPlatformOpenGLContext *QXcbXminIntegration::createPlatformOpenGLContext(
+    QOpenGLContext *context) const
+{
+    return new QXcbXminContext(m_connection, context);
+}
+#endif
