diff --git a/CMakeLists.txt b/CMakeLists.txt
index cf44b1c2..d67a4127 100644
--- a/CMakeLists.txt
+++ b/CMakeLists.txt
@@ -67,10 +67,57 @@ set(FLTK_VERSION ${FLTK_VERSION} CACHE STRING "FLTK version" FORCE)
 #######################################################################
 include(CMake/setup.cmake)
 
+option(FLTK_USE_XMIN "use the Xmin minimalist X11 client" OFF)
+if(FLTK_USE_XMIN)
+  find_package(Xmin CONFIG REQUIRED)
+  if(NOT TARGET Xmin::ToolkitX11)
+    message(FATAL_ERROR "FLTK_USE_XMIN requires an Xmin build with XMIN_BUILD_TOOLKIT_CLIENT enabled")
+  endif()
+  get_target_property(FLTK_XMIN_INCLUDE_DIRECTORIES
+    Xmin::ToolkitX11 INTERFACE_INCLUDE_DIRECTORIES)
+  if(TARGET Xmin::GL)
+    get_target_property(FLTK_XMIN_GL_INCLUDE_DIRECTORIES
+      Xmin::GL INTERFACE_INCLUDE_DIRECTORIES)
+  endif()
+  get_target_property(FLTK_XMIN_CLIENT_LIBRARY
+    Xmin::ClientX11 IMPORTED_LOCATION)
+  if(NOT FLTK_XMIN_CLIENT_LIBRARY)
+    get_target_property(_xmin_configurations
+      Xmin::ClientX11 IMPORTED_CONFIGURATIONS)
+    foreach(_xmin_configuration IN LISTS _xmin_configurations)
+      string(TOUPPER "${_xmin_configuration}" _xmin_configuration_upper)
+      get_target_property(FLTK_XMIN_CLIENT_LIBRARY Xmin::ClientX11
+        "IMPORTED_LOCATION_${_xmin_configuration_upper}")
+      if(FLTK_XMIN_CLIENT_LIBRARY)
+        break()
+      endif()
+    endforeach()
+  endif()
+  if(NOT FLTK_XMIN_CLIENT_LIBRARY)
+    message(FATAL_ERROR "Cannot locate the Xmin client library")
+  endif()
+  get_filename_component(FLTK_XMIN_LIBRARY_DIRECTORY
+    "${FLTK_XMIN_CLIENT_LIBRARY}" DIRECTORY)
+  set(FLTK_XMIN_LINK_FLAGS
+    "-L${FLTK_XMIN_LIBRARY_DIRECTORY}" -lXminClient)
+  list(APPEND CMAKE_REQUIRED_INCLUDES ${FLTK_XMIN_INCLUDE_DIRECTORIES})
+endif()
+
 #######################################################################
 # check for headers, libraries and functions
 #######################################################################
 include(CMake/resources.cmake)
+if(FLTK_USE_XMIN)
+  # Xmin supplies its focused Fontconfig surface and uses embedded fonts.
+  set(LIB_fontconfig "")
+  set(LIB_freetype "")
+  if(TARGET Xmin::GL)
+    set(LIB_GL Xmin::GL)
+  else()
+    set(LIB_GL "")
+    set(LIB_MesaGL "")
+  endif()
+endif()
 
 #######################################################################
 # options
