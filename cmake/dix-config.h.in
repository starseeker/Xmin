#ifndef _DIX_CONFIG_H_
#define _DIX_CONFIG_H_

/* Minimal compatibility configuration consumed by retained Xorg sources. */
#define HAVE_DIX_CONFIG_H 1

#cmakedefine HAVE_SYS_UN_H 1
#cmakedefine HAVE_POLL 1
#cmakedefine HAVE_SETITIMER 1
#cmakedefine HAVE_SIGPROCMASK 1
#cmakedefine HAVE_GETIFADDRS 1
#cmakedefine HAVE_GETPEEREID 1
#cmakedefine HAVE_GETPEERUCRED 1
#cmakedefine HAVE_GETADDRINFO 1
#cmakedefine HAVE_INET_NTOP 1
#cmakedefine HAVE_ISSETUGID 1
#cmakedefine HAVE_GETRESUID 1
#cmakedefine MONOTONIC_CLOCK 1
#cmakedefine HAVE_SOCKLEN_T 1
#cmakedefine HAVE_STRUCT_SOCKADDR_STORAGE 1
#cmakedefine NO_LOCAL_CLIENT_CRED 1
#cmakedefine HAVE_MMAP 1
#cmakedefine HAS_SHM 1
#cmakedefine MITSHM 1

/* Server-side protocols compiled into the normal Xmin profile. */
#define BIGREQS 1
#define RENDER 1
#define RANDR 1
#define PRESENT 1
#define DAMAGE 1
#define COMPOSITE 1
#define DBE 1
#define SCREENSAVER 1
#define XINERAMA 1
#define SHAPE 1
#define XCMISC 1
#define XFIXES 1
#define XSYNC 1
#define XTEST 1
#cmakedefine GLXEXT 1

#cmakedefine UNIXCONN 1
#cmakedefine TCPCONN 1
#cmakedefine LISTEN_UNIX 1
#cmakedefine LISTEN_LOCAL 1
#cmakedefine LISTEN_TCP 1
#define XMIN_LOCAL_ONLY_XTRANS @XMIN_LOCAL_ONLY_XTRANS@
#cmakedefine01 XTRANS_SEND_FDS
#define INPUTTHREAD 0

#define XMIN_DEFAULT_WIDTH @XMIN_DEFAULT_WIDTH@
#define XMIN_DEFAULT_HEIGHT @XMIN_DEFAULT_HEIGHT@
#define XMIN_DEFAULT_DEPTH @XMIN_DEFAULT_DEPTH@
#define XMIN_DEFAULT_DPI @XMIN_DEFAULT_DPI@

#cmakedefine HAVE_REALLOCARRAY 1
#cmakedefine HAVE_STRCASECMP 1
#cmakedefine HAVE_STRNCASECMP 1
#cmakedefine HAVE_STRCASESTR 1
#cmakedefine HAVE_STRLCAT 1
#cmakedefine HAVE_STRLCPY 1
#cmakedefine HAVE_STRNDUP 1
#cmakedefine HAVE_TIMINGSAFE_MEMCMP 1
#cmakedefine HAVE_VASPRINTF 1
#cmakedefine HAVE_FMEMOPEN 1
#cmakedefine HAVE_CBRT 1

#define PACKAGE_NAME "Xmin"
#define PACKAGE_STRING "Xmin @PROJECT_VERSION@"
#define PACKAGE_VERSION "@PROJECT_VERSION@"
#define XORG_VERSION_CURRENT \
    ((10000000) + (@PROJECT_VERSION_MAJOR@ * 100000) + \
     (@PROJECT_VERSION_MINOR@ * 1000) + @PROJECT_VERSION_PATCH@)

/* Xmin's core fonts will be exposed by an in-memory built-in FPE. */
#define COMPILEDDEFAULTFONTPATH "built-ins"

/* Xorg's framebuffer and wire conversion helpers require host byte order. */
#define X_BYTE_ORDER @XMIN_X_BYTE_ORDER@

/* Keep protocol scalar types 32-bit when the host ABI uses 64-bit long. */
#if @SIZEOF_LONG@ == 8
#define _XSERVER64 1
#endif

#endif
