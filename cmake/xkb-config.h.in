#ifndef _XKB_CONFIG_H_
#define _XKB_CONFIG_H_

/*
 * Compatibility defaults for the imported upstream XKB engine.  Xmin's
 * runtime path will replace file/rules compilation with a committed embedded
 * US PC105 map; these paths therefore deliberately name no host installation.
 */
#define XKB_DFLT_RULES "evdev"
#define XKB_DFLT_MODEL "pc105"
#define XKB_DFLT_LAYOUT "us"
#define XKB_DFLT_VARIANT ""
#define XKB_DFLT_OPTIONS ""
#define XKB_BASE_DIRECTORY ""
#define XKB_BIN_DIRECTORY ""
#define XKM_OUTPUT_DIR "/tmp/"

#endif
