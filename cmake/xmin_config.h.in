#ifndef XMIN_CONFIG_H
#define XMIN_CONFIG_H

#define XMIN_NAME "@PROJECT_NAME@"
#define XMIN_VERSION "@PROJECT_VERSION@"
#define XMIN_INSTALL_LIBDIR "@CMAKE_INSTALL_LIBDIR@"

#define XMIN_DEFAULT_WIDTH @XMIN_DEFAULT_WIDTH@
#define XMIN_DEFAULT_HEIGHT @XMIN_DEFAULT_HEIGHT@
#define XMIN_DEFAULT_DEPTH @XMIN_DEFAULT_DEPTH@
#define XMIN_DEFAULT_DPI @XMIN_DEFAULT_DPI@

#cmakedefine01 XMIN_BUILD_CLIENT_GL
#cmakedefine01 XMIN_BUILD_INDIRECT_GLX
#cmakedefine01 XMIN_ENABLE_TCP
#cmakedefine01 XMIN_BUILD_LAUNCHER
#cmakedefine01 XMIN_HAVE_UNIX_SOCKETS
#cmakedefine01 XMIN_HAVE_MITSHM
#cmakedefine01 XMIN_HAVE_GETRANDOM
#cmakedefine01 XMIN_HAVE_GETENTROPY
#cmakedefine01 XMIN_HAVE_ARC4RANDOM_BUF
#cmakedefine01 XMIN_HAVE_ACCEPT4
#cmakedefine01 XMIN_HAVE_PIPE2
#cmakedefine01 XMIN_IS_BIG_ENDIAN

#endif
