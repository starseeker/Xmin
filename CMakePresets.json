{
  "version": 3,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 21,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "dev",
      "displayName": "Developer build",
      "description": "Debug build with tests and a compilation database",
      "binaryDir": "${sourceDir}/build/dev",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON",
        "XMIN_BUILD_TESTS": "ON"
      }
    },
    {
      "name": "release",
      "displayName": "Release build",
      "binaryDir": "${sourceDir}/build/release",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "XMIN_BUILD_TESTS": "ON"
      }
    },
    {
      "name": "minimal",
      "displayName": "Minimal server-only build",
      "description": "Builds neither client OpenGL nor legacy indirect server GLX",
      "binaryDir": "${sourceDir}/build/minimal",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON",
        "XMIN_BUILD_TESTS": "ON",
        "XMIN_BUILD_CLIENT_GL": "OFF",
        "XMIN_BUILD_VIEWER": "OFF",
        "XMIN_BUILD_DESKTOP": "OFF",
        "XMIN_BUILD_BUNDLED_SHELL": "OFF"
      }
    },
    {
      "name": "sanitizer",
      "displayName": "ASan and UBSan",
      "description": "Portable Clang/GCC sanitizer gate for project and vendored code",
      "binaryDir": "${sourceDir}/build/sanitizer",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON",
        "XMIN_BUILD_TESTS": "ON",
        "XMIN_BUILD_CLIENT_GL": "OFF",
        "XMIN_BUILD_VIEWER": "OFF",
        "XMIN_BUILD_DESKTOP": "OFF",
        "XMIN_BUILD_BUNDLED_SHELL": "OFF",
        "XMIN_ENABLE_SANITIZERS": "ON",
        "XMIN_WARNINGS_AS_ERRORS": "ON"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "dev",
      "configurePreset": "dev"
    },
    {
      "name": "release",
      "configurePreset": "release"
    },
    {
      "name": "minimal",
      "configurePreset": "minimal"
    },
    {
      "name": "sanitizer",
      "configurePreset": "sanitizer"
    }
  ],
  "testPresets": [
    {
      "name": "dev",
      "configurePreset": "dev",
      "output": {
        "outputOnFailure": true
      }
    },
    {
      "name": "release",
      "configurePreset": "release",
      "output": {
        "outputOnFailure": true
      }
    },
    {
      "name": "minimal",
      "configurePreset": "minimal",
      "output": {
        "outputOnFailure": true
      }
    },
    {
      "name": "sanitizer",
      "configurePreset": "sanitizer",
      "environment": {
        "ASAN_OPTIONS": "strict_string_checks=1",
        "UBSAN_OPTIONS": "print_stacktrace=1:halt_on_error=1"
      },
      "output": {
        "outputOnFailure": true
      }
    }
  ]
}
